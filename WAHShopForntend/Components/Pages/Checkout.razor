	// Discount Code and discount Category
	private DiscountCodes discountCode = new();
	private DiscountCategory discountCategory = new();
	private bool IsDiscountCodeLoading = false;
	private async Task OnCode()
	{
		if (user == null || user.Id == 0)
		{
			MessageWarning = L["LoginForDiscount"].ToString();
			return;
		}

		IsDiscountCodeLoading = true;
		var result = await discountService.CheckDiscountCodeAsync(discountCode.Code, user.Id);
		if (result.validationResult.Result == true && result.discountCodes != null)
		{
			discountCode = result.discountCodes;
			discountCode.Message = null!;
			// discountcode category message empty if has content
			discountCategory.Message = null!;
		}
		else
		{
			// if discount code not valid, try to discount code of Category
			discountCategory.Code = discountCode.Code;
			// reset discount code
			discountCode = new();
			// check discount category code
			var result1 = await discountService.CheckDiscountCategoryAsync(discountCategory.Code.Trim(), user.Id);
			if (result1.validationResult.Result == true && result1.discountCategory != null)
			{
				discountCategory = result1.discountCategory;

				// check if the order has items in the category of the discount
				bool hasCategoryItems = cartService.CartItems.Any(item => item.Product.CategoryId == discountCategory.CategoriesId);
				if (hasCategoryItems)
					discountCategory.Message = null!;
				else
					discountCategory.Message = L["NoItemsInCategory"];
				// discountcode message empty if has content
				discountCode.Message = null!;
			}
			else
			{
				discountCategory = new();
				discountCategory.Message = result1.validationResult.Message!;
			}
		}
		IsDiscountCodeLoading = false;
	}
	private (double discountValue, double finalPrice) GetFinalPriceWithDiscount()
	{
		if (discountCode == null || discountCode.Id == 0)
		{
			return (0, cartService.GetTotalPrice());
		}
		double discountValue = 0;
		double totalPrice = cartService.GetTotalPrice();
		if (discountCode.DiscountType == DiscountType.Percentage)
			discountValue = (totalPrice * discountCode?.DiscountAmount / 100.0 ?? 0);
		else
			discountValue = discountCode?.DiscountAmount ?? 0;

		discountValue = Math.Min(discountValue, totalPrice);

		double finalPrice = totalPrice - discountValue;

		order.DiscountCodeId = discountCode!.Id;
		order.TotalPrice = finalPrice;

		return (discountValue, finalPrice);
	}
	private (double discountValue, double finalPrice) GetFinalPriceWithDiscountCategory()
	{
		if (discountCategory == null || discountCategory.Id == 0)
		{
			return (0, cartService.GetTotalPrice());
		}
		// get total price of category items
		double categoryitemsPrice = 0;
		foreach (var item in cartService.CartItems)
		{
			if (item.Product.CategoryId == discountCategory.CategoriesId)
			{
				categoryitemsPrice += cartService.GetTotalPriceOfProduct(item.ProductId);
			}
		}

		double categoryDiscountValue = 0;
		double totalPrice = cartService.GetTotalPrice();
		if (discountCategory.DiscountType == DiscountType.Percentage)
			categoryDiscountValue = categoryitemsPrice * discountCategory.DiscountAmount / 100.0;
		else
			categoryDiscountValue = discountCategory.DiscountAmount;

		
		categoryDiscountValue = Math.Min(categoryDiscountValue, categoryitemsPrice);
		// final price with discount of category
		double finalPrice = totalPrice - categoryDiscountValue;

		order.DiscountCategoryId = discountCategory.Id;
		order.TotalPrice = finalPrice;

		return (categoryDiscountValue, finalPrice);
	}
	private void GetFinalPrice()
	{
		order.TotalPrice = cartService.GetTotalPrice();
	}
	// user data update
	private UpdateProfile updateProfile = new UpdateProfile();
	private async Task OnUserUpdate()
	{
		updateProfile.UpdateType = UpdateTypeEnum.Birthday; // Assuming 3 is for birth date update
		var result = await authService.UpdateProfileAsync(updateProfile);
		if (!result.Result)
		{
			MessageWarning = result.Message?.ToString() ?? "Warnung Nachricht ist null gekommen";
		}
		else
		{
			user.BirthDate = updateProfile.BirthDate;
			MessageWarning = result.Message?.ToString() ?? "Warnung Nachricht ist null gekommen";
		}
		updateProfile = new UpdateProfile();
	}
	private bool IsBirthDateValid(string birthDate)
	{
		bool result = DateTime.TryParse(birthDate, out _);
		if (!result)
		{
			if (string.IsNullOrEmpty(updateProfile.BirthDate))
				updateProfile.BirthDate = "2015-01-01"; // set default value if empty)
			updateProfile.UserId = user.Id;
			updateProfile.UpdateType = UpdateTypeEnum.Birthday; // set birthday mode, weil in profile page wird password model gesetzt
		}
		return result;
	}
