@page "/orders"
@using System.Security.Claims
@inject IStringLocalizer< WAHShopForntend.Resources.Orders> L

@if (!IsRended)
{
    <div class="lodingContainer">
        <p>@L["Loading"] </p>
    </div>
}
else
{
        <h3>@L["MyOrders"]</h3>
        <div class="orderContainer">
            @foreach (var order in orderService.DownloadedOrders)
            {
                <div class="order">
                    <div class="orderHeader">
                        <h3>@L["OrderNo"] @order.Id</h3>
                        <span class="status">@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar"
                            ? order.Status?.Status_ar 
                            : order.Status?.Status_de ?? L["Unknown"])</span>
                    </div>
                    <p>
                        <span><strong>@L["PaymentMethod"]:</strong> @(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "ar" 
                            ? order.PaymentMethod?.Description_ar : order.PaymentMethod?.Description_de ?? "Keine Angabe")</span>
                        @if (order.Address is not null)
                        {
                            <span><strong>@L["DeliveryAddress"]:</strong> @order.Address.Street, @order.Address.ZipCode, @order.Address.City</span>
                        }
                    </p>

                    <p class="orderMeta">
                        <span><strong>@L["OrderDate"]:</strong> @order.OrderDate.ToString("dd.MM.yyyy HH:mm")</span>
                        <span><strong>@L["TotalPrice"]:</strong> @order.TotalPrice.ToString("C", new System.Globalization.CultureInfo("de-DE"))</span>
                    </p>

                    @if (!string.IsNullOrWhiteSpace(order.Notes))
                    {
                        <span><strong>@L["Notes"]:</strong> @order.Notes</span>
                    }

                    @if (order.OrderItems?.Count > 0)
                    {
                        <div class="orderItems">
                            @foreach (var item in order.OrderItems)
                            {
                                <div class="orderItem">
                                    <img @onclick="() => OnProduct(item.ProductId)" src="data:image/jpeg;base64,@Convert.ToBase64String(item.Product?.Image ?? Array.Empty<byte>())" alt="@item.Product?.Name_de" />
                                    <div class="orderItemsDetails">
                                        <h4>
                                            @(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar"
                                                ? item.Product?.Name_ar
                                                : @item.Product?.Name_de)
                                        </h4>
                                        <p>@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar" 
                                            ?item.Product?.Description_ar
                                                : item.Product?.Description_de)</p>
                                        <p>
                                            @L["Price"]: @item.Product?.SalePrice.ToString("C", new System.Globalization.CultureInfo("de-DE"))
                                            &nbsp; | &nbsp;
                                            @L["Quantity"]: @item.Quantity
                                            &nbsp; | &nbsp;
                                            <strong>@L["Total"]: @((item.Product?.SalePrice * item.Quantity ?? 0).ToString("C", new System.Globalization.CultureInfo("de-DE")))</strong>
                                        </p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            <button type="submit" class="btn btn-primary" @onclick="OnMoreLoad" disabled="@(IsOrdersLoading || AllItemsLoaded)">
                @if (IsOrdersLoading)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span class="ms-2">@L["Loading"]</span>
                }
                else if (!AllItemsLoaded)
                {
                    <span>@L["LoadMore"]</span>
                }
                @if (AllItemsLoaded)
                {
                    <span>@L["AllLoaded"]</span>
                }
            </button>
        </div>
}
@code {
    private bool IsRended = false;
    private int UserId = 0;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            string userIdString = user.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value!;
            if (!string.IsNullOrEmpty(userIdString))
            {
                UserId = int.Parse(userIdString);
            }
        }

        if (firstRender == true)
        {
            if (UserId > 0)
                await orderService.GetOrdersAsync(UserId);

            IsRended = true;
            StateHasChanged();
        }
    }
    // more load
    private bool IsOrdersLoading { get; set; } = false;
	private bool AllItemsLoaded { get; set; } = false;
    private async Task OnMoreLoad()
    {
        IsOrdersLoading = true;
		StateHasChanged();
        if (UserId > 0)
        {
            var result = await orderService.GetOrdersAsync(UserId);

            if (result.Result && result.Message == "AllItemsLoaded")
            {
				AllItemsLoaded = true;
            }
        }
        IsOrdersLoading = false;
        StateHasChanged();
    }
    // On Product Click
    private void OnProduct(int ProductId)
    {
        NavigationManager.NavigateTo($"/ProductPage/{ProductId}", true);
    }
}
