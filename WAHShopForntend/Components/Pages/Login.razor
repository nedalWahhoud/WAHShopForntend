@page "/login"
@inject IStringLocalizer< WAHShopForntend.Resources.Login> L

<div class="main">
    <div class="loginContainer">
        <div class ="loginForm">
            <EditForm style="display:flex;flex-direction:column;gap:10px;" Model="@loginModel" OnValidSubmit="@HandleSubmit">
                <DataAnnotationsValidator />
                <h2 @onclick="OnProjectInfo">@ProjectInfo.Value.Name</h2>
                <h3>@L["Welcome"]</h3>
                <div class="form-group">
                    <InputText @bind-Value="loginModel.Email"
                    placeholder="@L["Email"]"
                    class="form-control" />
                    <ValidationMessage For="@(() => loginModel.Email)" />
                </div>
                <div class="form-group">
                    <div class="passwordDiv">
                    <InputText @bind-Value="loginModel.Password"
                    type="@passwordInputType"
                    placeholder="@L["Password"]"
                    class="form-control passwordInput" />

                    <button type="button"
                    class="eyeButton"
                    @onclick="TogglePasswordVisibility">
                        <i class="bi @(loginModel.PasswordVisibility ? "bi-eye-slash" : "bi-eye")"></i>
                    </button>
                    </div>
                    <ValidationMessage For="@(() => loginModel.Password)" />
                </div>
                <div class="RememberMe">
                    <InputCheckbox @bind-Value="loginModel.RememberMe" />
                    <span>@L["RememberMe"]</span>
                </div>
                <button class="loginBtn" type="submit">@L["LoginText"]</button>
            </EditForm>
           @* <button @onclick="GoogleSingup" class="googleBtn">
                <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google Logo" />
            </button>*@
            <div>
                <p class="signup">
                    @L["NoAccountText"]
                    <a href="/signup"> @L["Register"]</a>
                </p>
            </div>
            <div>
                <p class="forgotPassword">
                    <a href="/forgotpassword">@L["ForgotPassword"]</a>
                </p>
            </div>
        </div>
    </div>
</div>

