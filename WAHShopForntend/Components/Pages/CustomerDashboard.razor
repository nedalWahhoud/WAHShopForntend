@using System.IdentityModel.Tokens.Jwt;
@using System.Security.Claims;
@namespace WAHShopForntend.Components.Layout
@inject IStringLocalizer<WAHShopForntend.Components.Layout.CustomerDashboard> L
@page "/customerDashboard"


@if (IsLoading)
{
	<div class="w-100 card-body text-center text-info">
		Lädt...
	</div>
}
else
{

	<div class="mainContainer">
		<div class="page-header mb-4">
			<h1 class="customer-title">
				<span class="text-muted fw-light">@L["AccountOf"]</span>
				<span class="d-block d-sm-inline-block fw-bold text-dark">@(customer?.Name_de ?? "Fehler")</span>
			</h1>
			<div class="titleUnderline"></div>
		</div>
		@* Schulden anzeigen *@
		<div class="card mb-3 shadow-sm border-0 balanceCard">
			<div class="cardBody p-3">
				<div class="d-flex align-items-center justify-content-between mb-2">
					<h6 class="text-muted fw-normal mb-0">@L["CurrentAmount"]</h6>
					<div class="iconCircle">
						<i class="bi bi-wallet2"></i>
					</div>
				</div>

				<div class="text-start">
					<h2 class="m-0 fw-bold @(debtCustomers?.Balance > 0 ? "text-danger" : "text-success") balanceText">
						@(debtCustomers?.Balance.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("de-DE")))
					</h2>
				</div>
			</div>
		</div>
		@* transactions anzeigen *@
			<div class="tableResponsive border rounded">
				<table class="table table-striped table-bordered mb-0 customTable">
					<thead class="table-dark">
						<tr>
							<th>@L["TransactionType"]</th>
							<th>@L["Amount"]</th>
							<th>@L["CreatedAt"]</th>
							<th>@L["Notes"]</th>
						</tr>
					</thead>
					<tbody>
						@if (transactionsCustomersService.DownloadedTransactionsCustomers != null && transactionsCustomersService.DownloadedTransactionsCustomers.Any())
						{
							foreach (var t in transactionsCustomersService.DownloadedTransactionsCustomers)
							{
								<tr>
									<td class="@(t.Type == TransactionType.Repay ? "text-success" : "text-danger")">@L[t.Type.ToString()]</td>
									<td>@t.Amount.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("de-DE"))</td>
									<td>@t.TransactionDate.ToString("dd.MM.yyyy HH:mm 'Uhr'")</td>
									<td>@t.Notes</td>
								</tr>
							}
						}
						else
						{
							<tr>
								<td colspan="6" class="text-center">Keine Transaktionen gefunden.</td>
							</tr>
						}
					</tbody>
				</table>
			    <div class="d-flex justify-content-center m-3">
				<button @onclick="OnMoreLoadTransactionsCustomers" class="btn btn-success btnMobileSmall"
						disabled="@(transactionsCustomersService.GetItems.AllItemsLoaded || IsProcessing)">
					@if (IsProcessing)
					{
						<span class="spinner-border spinner-border-sm"
							  role="status"
							  aria-hidden="true"></span>
					}
					else if (transactionsCustomersService.GetItems.AllItemsLoaded)
					{
						<span>@L["AllLoaded"]</span>
					}
					else
					{
						<span>@L["MoreLoading"]</span>
					}
				   </button>
			    </div>
			</div>
		<div class="mt-4 p-3 border-start border-4 border-info bg-light rounded shadow-sm">
			<div class="d-flex align-items-center">
				<i class="bi bi-info-circle-fill text-info me-3 fs-4"></i>
				<p class="mb-0 text-dark fw-medium">
					@L["AccountNotice"]
				</p>
			</div>
		</div>
	</div>
}

@code {

	[Parameter]
	[SupplyParameterFromQuery] 
	public string token { get; set; } = string.Empty;

	private bool IsProcessing = false;
	private Customers customer = new();
	private DebtCustomers debtCustomers = null!;
	private bool IsLoading = false;
	protected override async Task OnInitializedAsync()
	{
		IsLoading = true;

		// wenn über url message token
		if (string.IsNullOrEmpty(token))
		{
			// wenn token null von url dann über login prüfen ob angemeldet
			token = await JS.InvokeAsync<string>("localStorage.getItem", "jwtCustomerToken");
		}
	
		if (string.IsNullOrEmpty(token))
		{
            // Nicht angemeldet und kein token in url → Weiterleitung zur Anmeldeseite
            NavigationManager.NavigateTo("/customerLogin");
            return;
        }

        // Auszüge aus den Ansprüchen von JWT
        int? customerIdFromToken = customersService.GetIdentity(token);

        if (customerIdFromToken == null)
        {
            NavigationManager.NavigateTo("/customerPortal");
            return;
        }

        //Jetzt sicher → Kundendaten abrufen
        customer = await customersService.GetCustomerByIdAsync(customerIdFromToken.Value);

		// Schulden des Kunden abrufen
        debtCustomers = await debtService.GetDebtCustomerByIdAsync(customerIdFromToken.Value);
        debtCustomers ??= new DebtCustomers { CustomerId = customerIdFromToken.Value, Balance = 0 };

		// Transaktionen des Kunden laden
		// initialize TransactionsCustomers list
		transactionsCustomersService.GetItems = new GetItems<TransactionsCustomers> { Id = customerIdFromToken.Value, PageSize = 10, };
        await OnMoreLoadTransactionsCustomers();
		IsLoading = false;
    }

    private async Task OnMoreLoadTransactionsCustomers()
    {
        IsProcessing = true;

        // Load more transactions
        await transactionsCustomersService.GetTransactionsCustomersAsync();

        IsProcessing = false;
    }
}
