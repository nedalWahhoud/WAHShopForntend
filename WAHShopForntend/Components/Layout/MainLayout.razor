@inherits LayoutComponentBase

@if (!isRended)
{
    <div class="lodingContainer">
        <p>wird geladen... </p>
    </div>
}
else
{
    @if (!HeaderHidden)
    {
        <Header />
        <CategoryNav />
    }


    <div class="page">
        <main>
            <article class="content px-4">
                @Body
               
            </article>
           
        </main>
    </div>
     @if (!HeaderHidden && showFooter)
        {
            <Footer />
        }

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>
  
}
@code{
    private bool HeaderHidden => NavigationManager.Uri.Contains("login") || 
    NavigationManager.Uri.Contains("signup") || 
    NavigationManager.Uri.Contains("forgotpassword");
    private bool isRended = false;

    protected override async Task OnInitializedAsync()
    {
        await categoryService.GetCategories();
    }

    private bool showFooter = true;
    private DotNetObjectReference<MainLayout>? objRef;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isRended = true;
            // Initialize the cartService to get the saved cart
            await cartService.InitializeAsync();

            // footer

           /* objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("footerVisibility.initScrollWatcher", objRef);*/
            StateHasChanged();
        }
    }

