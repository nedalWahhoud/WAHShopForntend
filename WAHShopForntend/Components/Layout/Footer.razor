
<footer class="footer" id="page-footer">
	<div class="contactDiv">
		<h3>@ProjectInfo.Value.Name</h3>
		<p>
			<img src="Images/Location.png" alt="WhatsApp Icon" width="28" height="28" style="vertical-align: middle; margin-right: 5px;">
			@ProjectInfo.Value.Address
		</p>
		<p>
			<img src="Images/Whatsapp.png" alt="WhatsApp Icon" width="28" height="28" style="vertical-align: middle; margin-right: 5px;">
			@ProjectInfo.Value.Whatsapp
		</p>
		<p>
			<img src="Images/Email.png" alt="WhatsApp Icon" width="28" height="28" style="vertical-align: middle; margin-right: 5px;">
			@ProjectInfo.Value.Email
		</p>
	</div>
</footer>

