    @* Firebase *@
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.4.0/firebase-app.js";
        import {
            getAuth,
            GoogleAuthProvider,
            signInWithRedirect,
            getRedirectResult,
            signInWithPopup,
            signOut,
            onAuthStateChanged,
            setPersistence,
            browserLocalPersistence
        } from "https://www.gstatic.com/firebasejs/12.4.0/firebase-auth.js";

        
        const firebaseConfig = {
        apiKey: "AIzaSyDlKCI4GMUd9C6CYpVX53rMeAyV_NmcrI4",
        authDomain: "onlinestore-aa38e.firebaseapp.com",
        projectId: "onlinestore-aa38e",
        storageBucket: "onlinestore-aa38e.firebasestorage.app",
        messagingSenderId: "169699830284",
        appId: "1:169699830284:web:a87f8e73c3cd916d60dc29"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const provider = new GoogleAuthProvider();

        async function initFirebase() {
          try {
            await setPersistence(auth, browserLocalPersistence);
          } catch (errAwait) {
            console.warn("await setPersistence failed or not supported, trying .then():", errAwait);
            setPersistence(auth, browserLocalPersistence)
              .then(() => {
                console.log("✅ Persistence set (then)");
              })
              .catch(errThen => {
                console.error("❌ setPersistence failed:", errThen);
              });
          }
        }

        initFirebase();

        window.loginWithGoogleRedirect = async function () {
            try {
                await signInWithRedirect(auth, provider);
            } catch (error) {
                alert("Login failed: " + error.message);
            }
        };

          window.getRedirectResult = async function () {
          try {
            console.log("🔄 Checking redirect result...");
            const result = await getRedirectResult(auth);
            if (result && result.user) {
              console.log("✅ Redirect result found user:", result.user.email);
              return {
                UserName: result.user.displayName,
                Email: result.user.email,
                SignupProvider: "Google",
              };
            }

            return new Promise((resolve) => {
              onAuthStateChanged(auth, (user) => {
                if (user) {
                  console.log("✅ User loaded from onAuthStateChanged:", user.email);
                  resolve({
                    UserName: user.displayName,
                    Email: user.email,
                    SignupProvider: "Google",
                  });
                } else {
                  console.log("🚪 No user found (signed out)");
                  resolve(null);
                }
              });
            });
          } catch (error) {
            console.error("❌ Error getting redirect result:", error);
            return null;
          }
        };



        /*
        // login mit Popup
        window.loginWithGooglePopup = async function () {
            try {
                const result = await signInWithPopup(auth, provider);
                const user = result.user;
                return {
                    UserName: user.displayName,
                    Email: user.email,
					SignupProvider: "Google",
                };
            } catch (error) {
                console.error("Popup login failed:", error);
                return null;
            }
        };*/

        // log out
        window.googleSignOut = async function () {
            try {
                await signOut(auth);
                return true;
            } catch (error) {
                console.error("Sign out failed:", error);
                return false;
            }
        };
    </script>
