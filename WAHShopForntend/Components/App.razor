    @* confirm *@
	<script>
        window.showConfirm = function (message) {
          return confirm(message);
        }
	</script>
    @* Firebase *@
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.1.0/firebase-app.js";
        import {
            getAuth,
            GoogleAuthProvider,
            signInWithRedirect,
            getRedirectResult,
            signOut
        } from "https://www.gstatic.com/firebasejs/12.1.0/firebase-auth.js";

        // ✅ تهيئة Firebase باستخدام config الخاص بك
          const firebaseConfig = {
          apiKey: "AIzaSyDlKCI4GMUd9C6CYpVX53rMeAyV_NmcrI4",
          authDomain: "onlinestore-aa38e.firebaseapp.com",
          projectId: "onlinestore-aa38e",
          storageBucket: "onlinestore-aa38e.firebasestorage.app",
          messagingSenderId: "169699830284",
          appId: "1:169699830284:web:a87f8e73c3cd916d60dc29"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const provider = new GoogleAuthProvider();

        // ✅ دالة تسجيل الدخول بـ Redirect
        window.loginWithGoogle = async function () {
                   try {
                   alert("okay");
         await signInWithRedirect(auth, provider);
           
        } catch (error) {
          alert("Redirect error:", error.code, error.message);
        }

        };

        // ✅ دالة لجلب نتيجة تسجيل الدخول بعد العودة من Google
        async function getRedirectResultFromFirebase() {
            try {
                const result = await getRedirectResult(auth);
                if (result && result.user) {
                    const user = result.user;
                    return {
                        Username: user.displayName,
                        Email: user.email,
                        Uid: user.uid
                    };
                }
                return null;
            } catch (error) {
                console.error("Redirect login failed:", error);
                return null;
            }
        }
        window.getRedirectResult = getRedirectResultFromFirebase;

        // ✅ تسجيل خروج
        window.googleSignOut = async function () {
            try {
                await signOut(auth);
                return true;
            } catch (error) {
                return false;
            }
        };


        // تسجيل خروج
        window.googleSignOut = async function () {
            try {
                await signOut(auth);
                return true;
            } catch (error) {
                return false;
            }
        };
    </script>


    @* javscript import *@
    <script src="JS/script.js"></script>
    @* langauge cocikes *@
    <script>
        window.blazorCulture = {
            set: function (value) {
                document.cookie = `.AspNetCore.Culture=c=${value}|uic=${value}; path=/; SameSite=Lax`;
            },
            get: function () {
            return navigator.language || navigator.userLanguage;
        }
        };
    </script>
    @* footer hide and show *@
    <script>
        window.footerVisibility = {
            initScrollWatcher: function (dotNetHelper) {
                window.addEventListener("scroll", () => {
                    const scrollY = window.scrollY + window.innerHeight;
                    const pageHeight = document.body.offsetHeight;

                    if (scrollY >= pageHeight - 10) {
                        dotNetHelper.invokeMethodAsync("ShowFooter");
                    } else {
                        dotNetHelper.invokeMethodAsync("HideFooter");
                    }
                });
            }
        };
    </script>

</body>

</html>
